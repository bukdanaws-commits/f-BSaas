# ===========================================
# EVENTIFY - Environment Configuration Example
# ===========================================
# Copy this file to .env.local and fill in your values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_REQUIRE_EMAIL_CONFIRMATION=false

# Database Connection (Prisma/Next.js)
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"

# Golang Backend Integration
NEXT_PUBLIC_USE_GOLANG_BACKEND=true
NEXT_PUBLIC_GOLANG_API_URL=http://localhost:8080
GOLANG_API_URL=http://localhost:8080

# Google OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Midtrans Payment Gateway
MERCHANT_ID=your-merchant-id
MIDTRANS_SERVER_KEY=your-server-key
MIDTRANS_CLIENT_KEY=your-client-key
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=your-client-key

# App Configuration
NEXT_PUBLIC_APP_URL=your-domain.com

# JWT Configuration
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRY=24h
